# ==========================================
# IDEA2SOCDIA - LOCAL ENVIRONMENT TEMPLATE
# ==========================================

# --- 1. GOOGLE CLOUD CONFIGURATION (Required for Vertex AI & GCS) ---
# Your Google Cloud Project ID
GCP_PROJECT_ID=your-gcp-project-id
# Recommended region for Vertex AI media models (e.g., us-central1)
GCP_REGION=us-central1 
# The name of your Google Cloud Storage bucket to save generated media
GCS_BUCKET_NAME=your-gcs-bucket-name

# --- 2. GEMINI AI STUDIO ---
# API Key from Google AI Studio (Required for the main LLM Orchestrator)
GEMINI_API_KEY=your_gemini_api_key_here

# --- 3. SECURITY ---
# Password to access the UI (Backend verification)
APP_PASSWORD=your_secure_password_here